APP_NAME=AI Project Manager API
APP_ENV=development
APP_VERSION=0.6.0
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://project_manager:project_manager@db:5432/project_manager
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
SESSION_HASH_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TIMEOUT_SECONDS=90
OPENAI_REASONING_EFFORT=low
OPENAI_VERBOSITY=low
PLANNING_RUN_DEFAULT_TOKEN_BUDGET=50000
JOB_HEARTBEAT_SECONDS=15
JOB_LEASE_SECONDS=90
JOB_POLL_SECONDS=1

POSTGRES_DB=project_manager
POSTGRES_USER=project_manager
POSTGRES_PASSWORD=project_manager

VITE_API_BASE_URL=http://localhost:8000/api/v1
